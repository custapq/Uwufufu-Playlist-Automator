# --- UwuFufu Credentials ---
UWUFUFU_EMAIL=your_email@example.com
UWUFUFU_PASSWORD=your_password_here

# --- Playlist URL (Spotify or YouTube) ---
PLAYLIST_URL=https://open.spotify.com/playlist/xxxxxxxxxxxxxxxxxxxxxxxx

# --- Spotify API Credentials ---
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
# Used only for Spotify login (--spotify-login) to read your OWN playlists.
# Must be added to the Redirect URIs allowlist in your Spotify app dashboard, exactly.
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

