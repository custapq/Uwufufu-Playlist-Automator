# ============================================================
# .env.example — ตัวอย่าง environment variables
# ============================================================
# วิธีใช้:
#   1. Copy ไฟล์นี้เป็น .env
#      cp .env.example .env   (Mac/Linux)
#      copy .env.example .env (Windows)
#   2. แก้ไขค่าด้านล่างให้เป็นข้อมูลของคุณ
#   3. .env จะถูก gitignore — ไม่ถูก commit ขึ้น repo
# ============================================================

# --- UwuFufu Credentials ---
UWUFUFU_EMAIL=your_email@example.com
UWUFUFU_PASSWORD=your_password_here

# --- Spotify Playlist (optional) ---
# ถ้าตั้งไว้ โปรแกรมจะใช้ค่านี้โดยไม่ถาม
SPOTIFY_PLAYLIST_URL=https://open.spotify.com/playlist/xxxxxxxxxxxxxxxxxxxxxxxx
